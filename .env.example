# Runtime
TZ=Asia/Taipei
PYTHONUNBUFFERED=1

# Backend auth / CORS
SAU_API_TOKENS=replace-with-a-long-random-token
SAU_CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# Browser behavior
LOCAL_CHROME_PATH=
LOCAL_CHROME_HEADLESS=True
DEBUG_MODE=False
XHS_SERVER=http://127.0.0.1:11901

# LLM API (OpenAI-compatible)
SAU_LLM_API_BASE_URL=https://your-llm-endpoint.example.com
SAU_LLM_API_KEY=sk-dummy-replace-me

# Google Sheets export
# Prefer file mode for local development; point to a downloaded service-account JSON.
SAU_GOOGLE_SERVICE_ACCOUNT_FILE=./secrets/google-service-account.json
# Optional inline JSON alternative. Leave empty when using file mode.
SAU_GOOGLE_SERVICE_ACCOUNT_JSON=

# Optional at-rest cookie encryption
SAU_COOKIE_ENCRYPTION_KEY=

# Optional profile defaults / storage hints
SAU_DEFAULT_RCLONE_REMOTE=Onedrive-Yahooforsub-Tao
SAU_DEFAULT_RCLONE_PATH=Scripts-ssh-ssl-keys/SocialUpload
SAU_PUBLIC_URL_TEMPLATE=

# Telegram / legacy MTProto (optional if you only use bot-based posting)
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=replace-me
# Example structured account env names used by the new profile/account UI:
TELEGRAM_BOT_TOKEN_BRAND_A=123456:replace-me

# Reddit
REDDIT_CLIENT_ID_BRAND_A=replace-me
REDDIT_CLIENT_SECRET_BRAND_A=replace-me
REDDIT_REFRESH_TOKEN_BRAND_A=replace-me
REDDIT_USER_AGENT_BRAND_A=social-auto-upload/0.1 (brand-a)

# Facebook / Instagram / Threads (Meta)
FB_PAGE_TOKEN_BRAND_A=replace-me
IG_ACCESS_TOKEN_BRAND_A=replace-me
THREADS_ACCESS_TOKEN_BRAND_A=replace-me

# YouTube OAuth
YT_CLIENT_ID_BRAND_A=replace-me.apps.googleusercontent.com
YT_CLIENT_SECRET_BRAND_A=replace-me
YT_REFRESH_TOKEN_BRAND_A=replace-me

# TikTok Content Posting API
TIKTOK_ACCESS_TOKEN_BRAND_A=replace-me

# Discord
DISCORD_WEBHOOK_URL_BRAND_A=https://discord.com/api/webhooks/123/replace-me
