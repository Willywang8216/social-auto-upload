# Runtime
TZ=Asia/Taipei
PYTHONUNBUFFERED=1

# Backend auth / CORS
SAU_API_TOKENS=replace-with-a-long-random-token
SAU_CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# Browser behavior
LOCAL_CHROME_PATH=
LOCAL_CHROME_HEADLESS=True
DEBUG_MODE=False
XHS_SERVER=http://127.0.0.1:11901

# LLM API (OpenAI-compatible)
SAU_LLM_API_BASE_URL=https://your-llm-endpoint.example.com
SAU_LLM_API_KEY=sk-dummy-replace-me

# Google Sheets export
# Prefer file mode for local development; point to a downloaded service-account JSON.
SAU_GOOGLE_SERVICE_ACCOUNT_FILE=./secrets/google-service-account.json
# Optional inline JSON alternative. Leave empty when using file mode.
SAU_GOOGLE_SERVICE_ACCOUNT_JSON=

# Optional at-rest cookie encryption
SAU_COOKIE_ENCRYPTION_KEY=

# Optional at-rest encryption of the OAuth secrets inside account config_json
# (access/refresh tokens, app secrets). Independent of the cookie key above;
# base64-encoded 16/24/32 bytes. Unset = tokens stored as plaintext (unchanged).
#   python -c "import base64,secrets; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
SAU_CONFIG_ENCRYPTION_KEY=

# Optional profile defaults / storage hints
SAU_DEFAULT_RCLONE_REMOTE=Onedrive-Yahooforsub-Tao
SAU_DEFAULT_RCLONE_PATH=Scripts-ssh-ssl-keys/SocialUpload
SAU_PUBLIC_URL_TEMPLATE=

# Public callback overrides if you deploy on a different domain than up.iamwillywang.com
SAU_TIKTOK_CALLBACK_URL=https://socialupload.iamwillywang.com/oauth/tiktok/callback
SAU_REDDIT_CALLBACK_URL=https://up.iamwillywang.com/oauth/reddit/callback
SAU_YOUTUBE_CALLBACK_URL=https://up.iamwillywang.com/oauth/youtube/callback
SAU_META_CALLBACK_URL=https://up.iamwillywang.com/oauth/meta/callback
SAU_THREADS_CALLBACK_URL=https://up.iamwillywang.com/oauth/threads/callback

# Telegram / legacy MTProto (optional if you only use bot-based posting)
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=replace-me
# Example structured account env names used by the new profile/account UI:
TELEGRAM_BOT_TOKEN_BRAND_A=123456:replace-me

# Reddit OAuth
REDDIT_CLIENT_ID=replace-me
REDDIT_CLIENT_SECRET=replace-me
REDDIT_REDIRECT_URI=https://up.iamwillywang.com/oauth/reddit/callback
REDDIT_USER_AGENT=social-auto-upload/1.0 (contact: support@example.com)
# Example brand-specific values if you want multiple account/env aliases:
REDDIT_CLIENT_ID_BRAND_A=replace-me
REDDIT_CLIENT_SECRET_BRAND_A=replace-me
REDDIT_REFRESH_TOKEN_BRAND_A=replace-me
REDDIT_USER_AGENT_BRAND_A=social-auto-upload/0.1 (brand-a)

# Patreon OAuth (optional, for API-based account connection)
PATREON_CLIENT_ID=replace-me
PATREON_CLIENT_SECRET=replace-me
SAU_PATREON_CALLBACK_URL=https://socialupload.iamwillywang.com/oauth/patreon/callback

# Teaching Blog (GitHub Contents API)
SAU_TEACHING_BLOG_GITHUB_TOKEN=

# NW/SW Blog (sexualwill.com REST API)
SAU_NW_SW_BLOG_API_TOKEN=

# YouTube / Google OAuth
YT_CLIENT_ID=replace-me.apps.googleusercontent.com
YT_CLIENT_SECRET=replace-me
YOUTUBE_REDIRECT_URI=https://up.iamwillywang.com/oauth/youtube/callback
# Example brand-specific refresh-token alias:
YT_REFRESH_TOKEN_BRAND_A=replace-me

# Meta / Facebook / Instagram
META_APP_ID=replace-me
META_APP_SECRET=replace-me
META_REDIRECT_URI=https://up.iamwillywang.com/oauth/meta/callback
# Optional legacy direct token envs if you are not using the in-app OAuth connect flow:
FB_PAGE_TOKEN_BRAND_A=replace-me
IG_ACCESS_TOKEN_BRAND_A=replace-me

# Threads OAuth
THREADS_APP_ID=replace-me
THREADS_APP_SECRET=replace-me
THREADS_REDIRECT_URI=https://up.iamwillywang.com/oauth/threads/callback
# Optional legacy direct token env if you are not using the in-app OAuth connect flow:
THREADS_ACCESS_TOKEN_BRAND_A=replace-me

# TikTok Login Kit / Content Posting API
TIKTOK_CLIENT_KEY=replace-me
TIKTOK_CLIENT_SECRET=replace-me
TIKTOK_REDIRECT_URI=https://socialupload.iamwillywang.com/oauth/tiktok/callback
# Optional direct access-token alias for structured account config:
TIKTOK_ACCESS_TOKEN_BRAND_A=replace-me

# Discord
DISCORD_WEBHOOK_URL_BRAND_A=https://discord.com/api/webhooks/123/replace-me

# X / Twitter legacy note:
# The current structured account-management flow does not yet use these API keys directly.
# Posting still relies on the legacy browser/cookie path in this repo.
X_API_KEY=replace-me
X_API_KEY_SECRET=replace-me
X_BEARER_TOKEN=replace-me
X_ACCESS_TOKEN=replace-me
X_ACCESS_TOKEN_SECRET=replace-me
X_CLIENT_ID=replace-me
X_CLIENT_SECRET=replace-me

# --- Compatibility modes (Phase 4) ---
# auth_mode:    legacy (bearer token only, default) -> hybrid (bearer OR Google
#               session) -> oidc (Google session is the normal browser auth).
#               hybrid/oidc require SAU_GOOGLE_LOGIN_ENABLED=true.
# tenancy_mode: single (default) -> shadow (compute + log workspace scope) ->
#               enforced (require workspace ownership; arrives with the tenant
#               schema migration).
SAU_AUTH_MODE=legacy
SAU_TENANCY_MODE=single

# --- Google application login (OpenID Connect) — Phase 3 ---
# Disabled by default; the legacy SAU_API_TOKENS bearer flow keeps working.
# Set SAU_GOOGLE_LOGIN_ENABLED=true only after creating a dedicated Google Cloud
# OAuth 2.0 "Web application" client (SEPARATE from the YouTube client) and
# registering the redirect URI  <SAU_PUBLIC_BASE_URL>/auth/google/callback .
# When enabled, GOOGLE_LOGIN_CLIENT_ID/SECRET, SAU_PUBLIC_BASE_URL and SECRET_KEY
# become mandatory (the app refuses to start otherwise).
SAU_GOOGLE_LOGIN_ENABLED=false
GOOGLE_LOGIN_CLIENT_ID=replace-me
GOOGLE_LOGIN_CLIENT_SECRET=replace-me
# Canonical public origin; all OAuth callbacks are derived from it server-side.
SAU_PUBLIC_BASE_URL=https://up.example.com
# Where the browser is sent after login (defaults to SAU_PUBLIC_BASE_URL).
SAU_FRONTEND_ORIGIN=https://up.example.com
# Server-side session tuning (optional).
SESSION_COOKIE_NAME=__Host-sau_session
SESSION_IDLE_SECONDS=43200
SESSION_ABSOLUTE_SECONDS=1209600
# Required to sign/secure sessions in production.
SECRET_KEY=replace-me
# Optional: PostgreSQL for the repository layer (defaults to the SQLite file).
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/sau
