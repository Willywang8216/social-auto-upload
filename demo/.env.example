# TikTok Demo Recording — Environment Variables
# Copy this to .env and fill in your test credentials
# DO NOT commit real secrets to version control

# The app is running at:
APP_BASE_URL=http://localhost:5409

# TikTok test account credentials (for manual OAuth flow if needed)
# These are optional — the Playwright test can skip OAuth if already logged in
# TIKTOK_TEST_USERNAME=
# TIKTOK_TEST_PASSWORD=

# ─── MIMO TTS Voice Clone ────────────────────────────────────────────────────
# Uses Xiaomi MiMo-V2.5-TTS-VoiceClone for narration with your cloned voice.
# Get keys from: https://platform.xiaomimimo.com
MIMO_API_KEY=tp-xxxx
MIMO_API_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
MIMO_VOICE_SAMPLE=/home/will/social-auto-upload/111.m4a

# ─── Fallback: edge-tts (Microsoft neural voice) ─────────────────────────────
# Used when MIMO is unavailable (quota exhausted, invalid key, etc.)
# No configuration needed — edge-tts works out of the box.
